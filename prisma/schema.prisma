// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// For future scalability - user accounts and saved pins
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  savedPins  SavedPin[]
  likedPins  LikedPin[]
  createdPins Pin[]
}

model Pin {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String
  palette     String   // JSON array of colors
  seed        Int
  height      Int
  tags        String   // JSON array of tags
  authorId    String?
  author      String
  authorSeed  Int
  likesCount  Int      @default(0)
  savesCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  authorUser  User?      @relation(fields: [authorId], references: [id])
  savedBy     SavedPin[]
  likedBy     LikedPin[]
}

model SavedPin {
  id     String   @id @default(cuid())
  userId String
  pinId  String
  savedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  pin  Pin  @relation(fields: [pinId], references: [id], onDelete: Cascade)

  @@unique([userId, pinId])
}

model LikedPin {
  id     String   @id @default(cuid())
  userId String
  pinId  String
  likedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  pin  Pin  @relation(fields: [pinId], references: [id], onDelete: Cascade)

  @@unique([userId, pinId])
}
